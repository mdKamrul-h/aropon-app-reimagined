{
  "expo": {
    "name": "আরোপন",
    "slug": "aropon-rn",
    "scheme": "aropon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/logo-lockup.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.antarious.aropon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B5E20",
        "foregroundImage": "./assets/branding/logo-lockup.png"
      },
      "package": "com.antarious.aropon"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A2E10",
          "image": "./assets/branding/logo-lockup.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/branding/logo-lockup.png",
          "color": "#1B5E20"
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
